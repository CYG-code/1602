.checkin-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.checkin-item__top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.checkin-item__user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.checkin-item__avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.checkin-item__user-meta {
  min-width: 0;
}

.checkin-item__nick {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
}

.checkin-item__shop {
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
}

.checkin-item__time {
  color: #98a2b3;
  font-size: 22rpx;
  flex-shrink: 0;
}

.checkin-item__rating {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.checkin-item__left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.recommend-badge {
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
}

.recommend-badge--yes {
  background: rgba(76, 175, 80, 0.14);
  color: #2f7d32;
}

.recommend-badge--no {
  background: rgba(255, 86, 48, 0.12);
  color: #b42318;
}

.checkin-item__price {
  color: #475467;
  font-size: 23rpx;
}

.checkin-item__content {
  margin-top: 12rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.65;
}

.checkin-item__dish {
  margin-top: 10rpx;
  color: #1f2937;
  font-size: 24rpx;
}

.checkin-item__meal-wrap {
  margin-top: 12rpx;
}

.checkin-item__meal-title {
  color: #667085;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.checkin-item__images {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.checkin-item__image {
  width: 100%;
  height: 176rpx;
  border-radius: 12rpx;
  background: #f2f4f7;
}

.checkin-item__actions {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: nowrap;
}

.comment-btn,
.like-btn,
.share-btn,
.delete-btn {
  min-width: 92rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  font-size: 22rpx;
  text-align: center;
  white-space: nowrap;
  box-sizing: border-box;
  flex: 0 0 auto;
}

.comment-btn,
.like-btn,
.share-btn {
  color: #667085;
  background: #f2f4f7;
}

.like-btn--active {
  color: #2f7d32;
  background: rgba(76, 175, 80, 0.14);
}

.share-btn {
  margin: 0;
  border: none;
  width: 88rpx;
  min-width: 88rpx;
  max-width: 88rpx;
  flex: 0 0 88rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-btn::after {
  border: 0;
}

.delete-btn {
  min-width: 74rpx;
  padding: 0 12rpx;
  color: #b42318;
  background: rgba(255, 86, 48, 0.1);
  border: 1rpx solid rgba(180, 35, 24, 0.22);
}
