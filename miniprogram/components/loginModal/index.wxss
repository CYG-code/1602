.login-modal__mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  z-index: 1000;
}

.login-modal__panel {
  width: 100%;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx 28rpx 26rpx;
  box-shadow: 0 30rpx 64rpx rgba(15, 23, 42, 0.28);
}

.login-modal__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.login-modal__desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #667085;
  line-height: 1.6;
}

.login-modal__actions {
  margin-top: 24rpx;
  display: flex;
  gap: 14rpx;
}

.login-modal__btn {
  flex: 1;
  border-radius: 999rpx;
  line-height: 82rpx;
  font-size: 26rpx;
}

.login-modal__btn--ghost {
  background: #eef2f6;
  color: #475467;
}

.login-modal__btn--primary {
  background: #4caf50;
  color: #ffffff;
}
