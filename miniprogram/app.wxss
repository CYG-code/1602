page {
  min-height: 100%;
  background: #f7f8fa;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.5;
}

view,
text,
button,
input,
textarea,
navigator {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  line-height: inherit;
  border-radius: 0;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
}

.page-card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(31, 41, 55, 0.08);
  padding: 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.page-subtitle {
  color: #667085;
  font-size: 26rpx;
}

.placeholder {
  margin-top: 24rpx;
  color: #667085;
}
