.map-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef8ef 0%, #f7f8fa 220rpx);
  padding: 24rpx 24rpx 40rpx;
}

.map-page__hero {
  margin-bottom: 16rpx;
}

.map-page__title {
  font-size: 42rpx;
  font-weight: 700;
  color: #1f2937;
}

.map-page__subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #667085;
}

.search-card {
  display: flex;
  gap: 8rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 10rpx;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 14rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.filter-pill {
  min-width: 170rpx;
  text-align: center;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 12rpx 18rpx;
  color: #2f7d32;
  font-size: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.08);
}

.filter-pill--action {
  min-width: 120rpx;
  font-weight: 600;
}

.filter-summary {
  margin: -2rpx 2rpx 14rpx;
  color: #667085;
  font-size: 23rpx;
}

.search-input {
  flex: 1 1 auto;
  width: 0;
  background: #f4f6f8;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 74rpx;
  font-size: 26rpx;
}

.search-btn {
  width: 128rpx;
  min-width: 128rpx;
  max-width: 128rpx;
  padding: 0;
  flex: 0 0 128rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 16rpx;
  background: #4caf50;
  color: #ffffff;
  font-size: 24rpx;
}

.map-page__error,
.map-page__loading {
  margin-bottom: 14rpx;
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
}

.map-page__error {
  background: rgba(255, 152, 0, 0.14);
  color: #9a6700;
}

.map-page__loading {
  background: rgba(31, 41, 55, 0.08);
  color: #475467;
}

.shop-map {
  width: 100%;
  height: 760rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.12);
}

.map-page__controls {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.map-page__control {
  flex: 1;
  border-radius: 999rpx;
  background: #4caf50;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 84rpx;
}

.map-page__control--ghost {
  background: #ffffff;
  color: #388e3c;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.empty-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.08);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.empty-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #667085;
}

.empty-action {
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: #4caf50;
  color: #ffffff;
  font-size: 26rpx;
}

.map-page__card {
  margin-top: 16rpx;
}

.result-list {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 18rpx;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.08);
}

.result-list__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 10rpx;
}

.result-item {
  border-radius: 14rpx;
  padding: 14rpx 14rpx;
  background: #f6f8f9;
}

.result-item + .result-item {
  margin-top: 10rpx;
}

.result-item--active {
  background: rgba(76, 175, 80, 0.14);
  border: 1rpx solid rgba(56, 142, 60, 0.35);
}

.result-item__name {
  color: #1f2937;
  font-size: 27rpx;
  font-weight: 600;
}

.result-item__meta {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  display: flex;
  gap: 16rpx;
}

.manual-add-row {
  margin-top: 18rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.08);
}

.manual-add-tip {
  color: #475467;
  font-size: 24rpx;
}

.manual-add-btn {
  border-radius: 999rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  background: rgba(76, 175, 80, 0.14);
  color: #2f7d32;
  font-size: 24rpx;
}

.add-panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
}

.add-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 30rpx 60rpx rgba(15, 23, 42, 0.3);
  padding: 24rpx;
  z-index: 3;
}

.add-panel__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 14rpx;
}

.add-input {
  height: 78rpx;
  background: #f4f6f8;
  border-radius: 14rpx;
  padding: 0 18rpx;
  margin-top: 10rpx;
  font-size: 26rpx;
}

.add-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.add-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 82rpx;
}

.add-btn--ghost {
  background: #eef2f6;
  color: #4b5563;
}

.add-btn--primary {
  background: #4caf50;
  color: #ffffff;
}
