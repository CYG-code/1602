.favorites-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef8ef 0%, #f7f8fa 220rpx);
  padding: 24rpx;
}

.error-card,
.loading-card,
.empty-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  font-size: 25rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.error-card {
  color: #b42318;
  background: rgba(255, 86, 48, 0.08);
}

.loading-card,
.empty-card {
  color: #475467;
}

.shop-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.shop-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.shop-title {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 700;
}

.shop-meta {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #667085;
  font-size: 22rpx;
}

.shop-address {
  margin-top: 8rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.6;
}

.unfavorite-btn {
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #eef2f6;
  color: #667085;
  font-size: 24rpx;
  line-height: 68rpx;
}
