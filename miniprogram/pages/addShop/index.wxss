.add-shop-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef8ef 0%, #f7f8fa 200rpx);
  padding: 20rpx 20rpx calc(130rpx + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-tip {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #667085;
}

.field-title {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #374151;
}

.type-wrap {
  display: flex;
  gap: 10rpx;
}

.type-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 24rpx;
}

.type-pill--active {
  background: rgba(76, 175, 80, 0.16);
  color: #2f7d32;
  border: 1rpx solid rgba(47, 125, 50, 0.35);
}

.input {
  margin-top: 12rpx;
  height: 78rpx;
  border-radius: 14rpx;
  background: #f4f6f8;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #1f2937;
}

.input--small {
  flex: 1;
  margin-top: 0;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 23rpx;
}

.tag--active {
  background: rgba(76, 175, 80, 0.16);
  color: #2f7d32;
  border: 1rpx solid rgba(47, 125, 50, 0.35);
}

.selected-tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.selected-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(76, 175, 80, 0.16);
  color: #2f7d32;
  font-size: 23rpx;
}

.selected-tag__remove {
  font-size: 28rpx;
  line-height: 1;
}

.tag-panel {
  margin-top: 8rpx;
  border-radius: 12rpx;
  background: #f4f6f8;
  max-height: 250rpx;
  overflow-y: auto;
}

.tag-panel__item,
.tag-panel__create {
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  color: #374151;
}

.tag-panel__item + .tag-panel__item {
  border-top: 1rpx solid #e5e7eb;
}

.tag-panel__create {
  color: #2f7d32;
  font-weight: 600;
}

.shop-image-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.shop-image-item {
  position: relative;
}

.shop-image {
  width: 100%;
  height: 180rpx;
  border-radius: 14rpx;
  background: #eef2f6;
}

.shop-image-remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.68);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.shop-image-add {
  height: 180rpx;
  border-radius: 14rpx;
  border: 2rpx dashed #b8c1cc;
  background: #f8fafc;
  color: #667085;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pick-map {
  margin-top: 14rpx;
  width: 100%;
  height: 520rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.coord-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.coord-text {
  font-size: 23rpx;
  color: #667085;
}

.btn-location {
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #4caf50;
  color: #ffffff;
  font-size: 25rpx;
  line-height: 72rpx;
}

.suggested-row {
  margin-top: 12rpx;
  background: #f4f6f8;
  border-radius: 14rpx;
  padding: 12rpx;
}

.suggested-text {
  color: #475467;
  font-size: 23rpx;
  line-height: 1.5;
}

.btn-suggested {
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: rgba(76, 175, 80, 0.18);
  color: #2f7d32;
  font-size: 24rpx;
  line-height: 62rpx;
}

.error-card,
.success-card {
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  font-size: 23rpx;
  margin-bottom: 12rpx;
}

.error-card {
  background: rgba(255, 152, 0, 0.16);
  color: #9a6700;
}

.success-card {
  background: rgba(76, 175, 80, 0.14);
  color: #2f7d32;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(247, 248, 250, 0.96);
  backdrop-filter: blur(8rpx);
}

.btn-submit {
  border-radius: 999rpx;
  background: #4caf50;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 84rpx;
}
